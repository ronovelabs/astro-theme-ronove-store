---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white mt-auto">
  <div class="container-custom py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <h3 class="text-2xl font-bold mb-4">Ronove Store</h3>
        <p class="text-gray-400 mb-4">
          Tu tienda online de confianza. Productos de calidad con envío a todo el país.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Enlaces</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-400 hover:text-white transition-colors">Inicio</a></li>
          <li><a href="/productos" class="text-gray-400 hover:text-white transition-colors">Productos</a></li>
          <li><a href="/nosotros" class="text-gray-400 hover:text-white transition-colors">Nosotros</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Contacto</h4>
        <ul class="space-y-2 text-gray-400">
          <li>Medellín, Colombia</li>
          <li>hola@ronove.store</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
      <p>&copy; {currentYear} Ronove Store. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
