---
const currentYear = new Date().getFullYear();

const footerLinks = {
  shop: [
    { label: 'Novedades', href: '/new-drops' },
    { label: 'Hombre', href: '/hombre' },
    { label: 'Mujer', href: '/mujer' },
    { label: 'Sale', href: '/sale' },
  ],
  help: [
    { label: 'Preguntas Frecuentes', href: '/faq' },
    { label: 'Envíos', href: '/envios' },
    { label: 'Devoluciones', href: '/devoluciones' },
    { label: 'Tallas', href: '/tallas' },
  ],
  company: [
    { label: 'Nosotros', href: '/nosotros' },
    { label: 'Contacto', href: '/contacto' },
    { label: 'Términos', href: '/terminos' },
    { label: 'Privacidad', href: '/privacidad' },
  ],
};
---

<footer class="bg-black text-white" aria-label="Footer">
  <div class="container-custom py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {/* Brand */}
      <div class="lg:col-span-1">
        <h3 class="text-2xl font-bold mb-4">RONOVE</h3>
        <p class="text-gray-400 mb-6">
          Moda urbana con estilo único. Productos de calidad para quienes buscan destacar.
        </p>
        
        {/* Newsletter */}
        <div class="mb-6">
          <h4 class="font-medium mb-2">Suscríbete</h4>
          <form class="flex">
            <input
              type="email"
              placeholder="Tu email"
              class="flex-1 px-4 py-2 bg-gray-800 text-white border-none focus:ring-1 focus:ring-yellow-400"
            />
            <button
              type="submit"
              class="px-4 py-2 bg-yellow-400 text-black font-medium hover:bg-yellow-300 transition-colors"
            >
              →
            </button>
          </form>
        </div>
        
        {/* Social */}
        <div class="flex gap-4">
          <a href="https://instagram.com/ronove.store" target="_blank" rel="noopener" aria-label="Instagram" class="hover:text-yellow-400 transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
      
      {/* Links */}
      <div>
        <h4 class="font-bold mb-4">TIENDA</h4>
        <ul class="space-y-2">
          {footerLinks.shop.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="font-bold mb-4">AYUDA</h4>
        <ul class="space-y-2">
          {footerLinks.help.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="font-bold mb-4">COMPAÑÍA</h4>
        <ul class="space-y-2">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    {/* Bottom */}
    <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-gray-400 text-sm">© {currentYear} RONOVE. Todos los derechos reservados.</p>
      <div class="flex gap-4 mt-4 md:mt-0">
        <img src="https://via.placeholder.com/40x25?text=VISA" alt="Visa" class="h-6" loading="lazy" />
        <img src="https://via.placeholder.com/40x25?text=MC" alt="Mastercard" class="h-6" loading="lazy" />
        <img src="https://via.placeholder.com/40x25?text=AMEX" alt="Amex" class="h-6" loading="lazy" />
      </div>
    </div>
  </div>
</footer>
