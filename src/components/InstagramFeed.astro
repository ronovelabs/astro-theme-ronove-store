---
// Instagram Feed
const posts = [
  { id: 1, image: 'https://images.unsplash.com/photo-1556906781-9a412961c28c?w=400&q=80', link: 'https://instagram.com/ronove.store' },
  { id: 2, image: 'https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=400&q=80', link: 'https://instagram.com/ronove.store' },
  { id: 3, image: 'https://images.unsplash.com/photo-1618354691373-d9c64f3c1d3f?w=400&q=80', link: 'https://instagram.com/ronove.store' },
  { id: 4, image: 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400&q=80', link: 'https://instagram.com/ronove.store' },
  { id: 5, image: 'https://images.unsplash.com/photo-1552374196-1ab2a1c593e6?w=400&q=80', link: 'https://instagram.com/ronove.store' },
  { id: 6, image: 'https://images.unsplash.com/photo-1617137968427-85924c800a22?w=400&q=80', link: 'https://instagram.com/ronove.store' },
];
---

<section class="py-16 bg-white" aria-label="Instagram">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-black mb-2">SÍGUENOS</h2>
      <a href="https://instagram.com/ronove.store" target="_blank" rel="noopener" class="text-gray-600 hover:text-black transition-colors">
        @ronove.store
      </a>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {posts.map((post) => (
        <a href={post.link} target="_blank" rel="noopener" class="group relative aspect-square overflow-hidden">
          {/* Skeleton */}
          <div class="absolute inset-0 bg-gray-200 animate-pulse"></div>
          
          <img
            src={post.image}
            alt="Instagram post"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            loading="lazy"
            onload="this.previousElementSibling.style.display='none'"
          />
          
          {/* Hover overlay */}
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/50 transition-colors flex items-center justify-center">
            <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
