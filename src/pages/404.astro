---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 - Página no encontrada">
  <Header />
  
  <main class="flex-grow flex items-center justify-center py-20">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-primary-600 mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-gray-900 mb-4">Página no encontrada</h2>
      <p class="text-gray-600 mb-8">La página que buscas no existe o fue movida.</p>
      <a href="/" class="btn-primary">Volver al inicio</a>
    </div>
  </main>
  
  <Footer />
</Layout>
