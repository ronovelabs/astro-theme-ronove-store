---
import { SEO } from 'astro-seo';
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import HeaderV2 from '../components/HeaderV2.astro';
import HeroSlider from '../components/HeroSlider.astro';
import ProductCarousel from '../components/ProductCarousel.astro';
import BannerSlider from '../components/BannerSlider.astro';
import CategoriesGrid from '../components/CategoriesGrid.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import FooterV2 from '../components/FooterV2.astro';

const title = 'RONOVE - Moda Urbana con Estilo Único';
const description = 'Descubre la nueva colección de ropa urbana en RONOVE. Envío gratis en compras superiores a $50.000. Entrega en 24-48h.';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: 'https://ronovelabs.github.io/astro-theme-ronove-store/og-image.jpg',
          url: 'https://ronovelabs.github.io/astro-theme-ronove-store',
        },
        optional: {
          description,
          locale: 'es_CO',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        site: '@ronove.store',
        title,
        description,
        image: 'https://ronovelabs.github.io/astro-theme-ronove-store/og-image.jpg',
      }}
    />
    
    <!-- Preconnect to image domains -->
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
  </head>
  
  <body class="min-h-screen flex flex-col">
    <TopBar />
    <HeaderV2 />
    
    <main>
      <HeroSlider />
      
      <ProductCarousel 
        title="NEW DROPS" 
        showViewAll={true} 
      />
      
      <BannerSlider />
      
      <ProductCarousel 
        title="LO MÁS VENDIDO" 
        showViewAll={true} 
      />
      
      <CategoriesGrid />
      
      <InstagramFeed />
    </main>
    
    <FooterV2 />
  </body>
</html>
