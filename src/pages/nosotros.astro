---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Nosotros - Ronove Store">
  <Header />
  
  <main class="flex-grow">
    <div class="bg-gray-900 text-white py-12">
      <div class="container-custom">
        <h1 class="text-4xl font-bold">Sobre Nosotros</h1>
        <p class="text-gray-300 mt-2">Conoce nuestra historia</p>
      </div>
    </div>
    
    <section class="py-16">
      <div class="container-custom max-w-3xl">
        <p class="text-lg text-gray-600 leading-relaxed">
          Ronove Store nació con la misión de ofrecer productos de calidad a precios accesibles.
          Somos un equipo apasionado por el comercio digital y comprometido con la satisfacción
          de nuestros clientes.
        </p>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
